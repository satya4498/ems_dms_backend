{
  "name": "dms-backend",
  "version": "1.0.0",
  "description": "Backend for dms system APIs",
  "main": "index.js",
  "engines": {
    "node": ">=20 <21",
    "npm": ">=10 <11"
  },
  "scripts": {
    "babel-node": "babel-node --inspect=0.0.0.0:9229",
    "build": "babel . -d dist --copy-files --delete-dir-on-start",
    "start": "node ./dist/index",
    "start:dev": "nodemon --exec npm run babel-node -- ./index.js",
    "lint": "standard --fix",
    "db:migrate": "sequelize db:migrate",
    "db:seed": "sequelize db:seed:all",
    "db:init": "npm run build && sequelize db:create && npm run db:migrate && npm run db:seed",
    "db:reset": "npm run build && sequelize db:drop && sequelize db:create && npm run db:migrate && npm run db:seed"
  },
  "author": "Satyam",
  "license": "ISC",
  "dependencies": {
    "@alt3/sequelize-to-json-schemas": "0.3.56",
    "@aws-sdk/client-s3": "3.511.0",
    "@aws-sdk/lib-storage": "3.511.0",
    "@faker-js/faker": "8.4.1",
    "@sentry/node": "^8.46.0",
    "@socket.io/redis-adapter": "8.2.1",
    "@socket.io/redis-emitter": "5.1.0",
    "ajv": "8.8.2",
    "ajv-formats": "2.1.1",
    "ajv-keywords": "5.1.0",
    "axios": "^1.6.7",
    "bcrypt": "5.0.1",
    "child_process": "1.0.2",
    "convict": "6.2.4",
    "cors": "2.8.5",
    "dayjs": "1.11.10",
    "dotenv": "10.0.0",
    "express": "4.18.2",
    "express-basic-auth": "1.2.1",
    "flatted": "3.2.4",
    "helmet": "6.0.1",
    "http-status-codes": "2.2.0",
    "ioredis": "5.3.1",
    "json2csv": "5.0.7",
    "jsonwebtoken": "9.0.2",
    "lodash": "4.17.21",
    "morgan": "1.10.0",
    "multer": "1.4.5-lts.1",
    "node-cache": "5.1.2",
    "node-mailjet": "6.0.5",
    "number-precision": "1.6.0",
    "pg": "8.6.0",
    "pg-hstore": "2.3.4",
    "prettier": "3.2.5",
    "sequelize": "6.34.0",
    "sequelize-cli": "6.6.1",
    "socket.io": "4.7.4",
    "twilio": "^5.7.0",
    "umzug": "3.8.0",
    "uuid": "9.0.1",
    "web-push": "3.6.7",
    "winston": "3.3.3"
  },
  "devDependencies": {
    "@babel/cli": "8.0.0",
    "@babel/core": "8.0.0",
    "@babel/eslint-parser": "8.0.1",
    "@babel/node": "8.0.0",
    "@babel/preset-env": "8.0.0",
    "babel-plugin-module-resolver": "5.0.3",
    "eslint": "9.17.0",
    "husky": "7.0.4",
    "lint-staged": "12.1.2",
    "nodemon": "3.0.2",
    "standard": "17.0.0"
  },
  "standard": {
    "parser": "@babel/eslint-parser",
    "env": {
      "jest": true,
      "browser": true,
      "node": true
    }
  },
  "lint-staged": {
    "src/**/*.js": [
      "npm run lint"
    ]
  }
}
